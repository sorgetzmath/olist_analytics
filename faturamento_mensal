-- Objetivo: identificar a flutuação do faturamento
-- Insight esperado: o negócio está crescendo ou decaindo
select
  to_char(order_purchase_timestamp, 'yyyy/MM') as mes,
  sum(i.price) as faturamento
from customer_dataset as c
join orders_dataset as o
on c.customer_id = o.customer_id
join order_items_dataset as i
on o.order_id = i.order_id
group by to_char(order_purchase_timestamp, 'yyyy/MM')
order by mes

select order_purchase_timestamp from orders_dataset
order by order_purchase_timestamp desc
